Vagrant.configure("2") do |config|
  # Define the Domain Controller
  config.vm.define "dc" do |dc|
    dc.vm.box = "gusztavvargadr/windows-server"
    dc.vm.hostname = "DC01"
    dc.vm.network "private_network", ip: "192.168.56.10"
    dc.vm.provider "virtualbox" do |vb|
      vb.memory = "4096"
      vb.cpus = 2
      vb.name = "VulnAD-DC01"
    end
    
    # Sync the scripts folder to the DC
    dc.vm.synced_folder "../scripts", "C:\\Scripts"

    # Provisioning script
    dc.vm.provision "shell", path: "../scripts/Setup-Lab.ps1"
    
    # Needs vagrant-reload plugin for handling reboot after AD promotion
    unless Vagrant.has_plugin?("vagrant-reload")
      puts "vagrant-reload plugin is missing. Please install it using 'vagrant plugin install vagrant-reload'"
    end
    dc.vm.provision :reload
  end

  # Define the Windows 10 Workstation
  config.vm.define "ws" do |ws|
    ws.vm.box = "gusztavvargadr/windows-10"
    ws.vm.hostname = "WS01"
    ws.vm.network "private_network", ip: "192.168.56.11"
    ws.vm.provider "virtualbox" do |vb|
      vb.memory = "4096"
      vb.cpus = 2
      vb.name = "VulnAD-WS01"
    end
    
    # Set the DNS server to the DC
    ws.vm.provision "shell", inline: "Set-DnsClientServerAddress -InterfaceAlias 'Ethernet 2' -ServerAddresses '192.168.56.10'"

    # Join domain (optional script if desired, right now just configuring networking is sufficient for basic attacks)
  end
end
